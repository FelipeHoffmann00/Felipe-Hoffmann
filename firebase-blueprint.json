{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Contact form submissions from potential leads or clients.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the person contacting."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the person contacting."
        },
        "message": {
          "type": "string",
          "description": "The message sent by the person."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created."
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of contact messages."
    }
  }
}
