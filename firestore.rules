rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Leads collection: anyone can create, no one can read/delete (except admin if exists)
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      // No standard read/list/update for visitors for privacy
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 5 && data.email.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }
  }
}
