rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == 'fg.hoffmann3@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) 
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    // --- Collections ---
    match /leads/{leadId} {
      // Anyone can send a message
      allow create: if isValidLead(incoming()) && (leadId == null || isValidId(leadId));
      
      // Only admin can see messages (PII Protection)
      allow read, list: if isAdmin();
      
      // Messages are immutable once sent
      allow update, delete: if isAdmin();
    }
  }
}
